PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/booking_system

# Required: every /api/* request must send this value in an x-api-key header.
# Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
API_KEY=your_api_key_here

# Optional: if set, reminders are emailed via Resend instead of just logged
# to the console. REMINDER_FROM_EMAIL must be a sender Resend allows for
# your account (a verified domain, or Resend's onboarding@resend.dev / any
# @resend.dev address for testing without a verified domain).
RESEND_API_KEY=your_resend_key_here
REMINDER_FROM_EMAIL=reminders@resend.dev
